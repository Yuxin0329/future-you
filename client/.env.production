# API 基础 URL
# 注意：部署到 Cloudflare Pages 后，这里需要改成后端服务的地址

# 选项1：继续用 ngrok（不稳定，但免费）
VITE_API_BASE_URL=https://unlucky-erik-emboly.ngrok-free.dev

# 选项2：部署到 Railway/Render 后，改成新地址
# VITE_API_BASE_URL=https://your-railway-app.railway.app

# 选项3：部署到云服务器，改成新地址
# VITE_API_BASE_URL=https://your-cloud-server-ip:3000

# 使用说明：
# 1. 根据你的实际部署情况，选择一个选项，取消注释
# 2. 删除其他选项（前面加 #）
# 3. 确保只有一行 VITE_API_BASE_URL 没有注释
# 4. 保存文件
# 5. 重新构建前端：npm run build
# 6. 上传新的 dist 目录到 Cloudflare Pages
